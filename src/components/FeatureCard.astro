---
interface Props {
	title: string;
	description: string;
	delay?: string;
}

const { title, description, delay } = Astro.props;
---
<div class="reveal card-premium p-6 sm:p-8 hover:-translate-y-1.5" style={`transition-delay: ${delay || '0ms'}`}>
	<div class="w-12 h-12 rounded-xl bg-secondary/10 border border-secondary/20 flex items-center justify-center mb-6 group-hover:bg-secondary/15 group-hover:scale-110 group-hover:border-secondary/30 transition-all duration-500">
		<slot name="icon" />
	</div>
	<h3 class="font-bold text-lg text-foreground group-hover:text-secondary transition-colors duration-300">{title}</h3>
	<p class="mt-3 text-sm text-muted-foreground leading-relaxed">{description}</p>
</div>
