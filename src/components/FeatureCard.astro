---
interface Props {
	title: string;
	description: string;
	delay?: string;
}

const { title, description, delay } = Astro.props;
---
<div class="reveal glass rounded-2xl p-8 group hover:border-primary/40 transition-all hover:-translate-y-1" style={`transition-delay: ${delay || '0ms'}`}>
	<div class="w-14 h-14 rounded-2xl bg-primary/10 border border-primary/20 flex items-center justify-center mb-8 group-hover:bg-primary/20 group-hover:scale-110 transition-all duration-500">
		<slot name="icon" />
	</div>
	<h3 class="font-semibold text-2xl text-foreground group-hover:text-primary transition-colors">{title}</h3>
	<p class="mt-4 text-muted-foreground leading-relaxed text-base">{description}</p>
</div>
