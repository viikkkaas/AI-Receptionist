---
interface Props {
  delay?: string;
}

const { delay = '0ms' } = Astro.props;

const stats = [
  {
    value: '100%',
    label: 'Call answer rate',
    description: 'Never miss another patient call. Available 24/7/365.',
  },
  {
    value: '21+',
    label: 'Appointments booked/month',
    description: 'Average per practice. Recovered from previously missed calls.',
  },
  {
    value: '$10K+',
    label: 'Additional monthly revenue',
    description: 'Estimated production generated from recovered appointments.',
  },
];
---

<section id="results" class="py-14 sm:py-28 scroll-mt-24 bg-white" style={`transition-delay: ${delay}`}>
  <div class="container-custom">
    <div class="reveal max-w-3xl mx-auto text-center mb-16">
      <div class="inline-flex items-center gap-2 rounded-full bg-secondary/10 px-4 py-1.5 text-xs font-semibold text-secondary mb-5">
        Proven Results
      </div>
      <h2 class="text-3xl sm:text-4xl md:text-5xl font-bold tracking-tight text-primary">
        Turn missed calls into <span class="text-gradient">booked</span> appointments.
      </h2>
      <p class="mt-4 text-muted-foreground text-lg max-w-2xl mx-auto">
        Real outcomes from dental practices that switched to CareReceptionist AI.
      </p>
    </div>

    <div class="grid md:grid-cols-3 gap-6 max-w-5xl mx-auto">
      {stats.map((stat, i) => (
        <div 
          class="reveal relative group flex flex-col items-center text-center p-8 rounded-3xl bg-white border border-border hover:border-secondary/30 hover:shadow-lg transition-all duration-500" 
          style={`transition-delay: ${parseInt(delay) + (i + 1) * 100}ms`}
        >
          {/* Elegant separator lines between cards (except last) */}
          {i < stats.length - 1 && (
            <div class="hidden md:block absolute top-1/2 right-[-3rem] w-6 h-px bg-gradient-to-r from-border to-transparent -translate-y-1/2" />
          )}
          
          <div class="relative z-10 mb-6">
            <span class="text-4xl sm:text-5xl md:text-6xl font-bold tracking-tight text-primary gradient-accent bg-clip-text text-transparent">
              {stat.value}
            </span>
          </div>
          
          <h3 class="relative z-10 font-bold text-xl sm:text-2xl text-primary mb-3">
            {stat.label}
          </h3>
          
          <p class="relative z-10 text-sm sm:text-base text-muted-foreground leading-relaxed max-w-xs mx-auto">
            {stat.description}
          </p>
          
          {/* Subtle glow accent on hover */}
          <div class="absolute inset-0 rounded-3xl bg-gradient-to-br from-secondary/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none" />
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  /* Ensure the gradient text works properly */
  .text-gradient {
    background: linear-gradient(to right, var(--color-primary), var(--color-secondary));
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }
</style>