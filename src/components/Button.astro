---
interface Props {
	title?: string;
	variant?: 'primary' | 'secondary' | 'ghost';
	href?: string;
}

const { title, variant = 'primary', href = 'https://calendly.com/vikas-p-2706/30min' } = Astro.props;

const baseClasses = 'inline-flex items-center justify-center gap-2 rounded-xl px-6 py-3.5 text-sm font-bold transition-all duration-300';

const variants = {
	primary: 'gradient-accent text-primary-foreground shadow-glow hover:scale-[1.03] hover:shadow-[0_0_30px_rgba(59,130,246,0.25)] active:scale-[0.98]',
	secondary: 'border-2 border-border bg-white text-foreground hover:border-secondary/40 hover:text-secondary hover:bg-secondary/5 active:scale-[0.98]',
	ghost: 'text-muted-foreground hover:text-foreground hover:bg-muted/50 active:scale-[0.98]',
};
---
<a href={href} target="_blank" rel="noopener noreferrer" class={`${baseClasses} ${variants[variant]}`}>
	{title || "Book Free Demo"}
	{variant === 'primary' && (
		<svg class="w-4 h-4 transform transition-transform duration-300 group-hover:translate-x-0.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
			<path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3" />
		</svg>
	)}
</a>
