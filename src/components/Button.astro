---
interface Props {
	title?: string;
	variant?: 'primary' | 'secondary' | 'ghost' | 'accent' | 'outline-white';
	href?: string;
	size?: 'default' | 'lg';
	target?: string;
	rel?: string;
}

const { title, variant = 'primary', href = 'https://calendly.com/vikas-p-2706/30min', size = 'default', target = '_blank', rel = 'noopener noreferrer' } = Astro.props;

const baseClasses = 'inline-flex items-center justify-center gap-2 font-bold transition-all duration-300';

const sizeClasses = {
	default: 'rounded-xl px-6 py-3.5 text-sm',
	lg: 'rounded-xl px-8 py-4 text-base',
};

const variants = {
	primary: 'rounded-xl gradient-accent text-primary-foreground shadow-glow hover:scale-[1.03] hover:shadow-[0_0_30px_rgba(5,150,105,0.25)] active:scale-[0.98]',
	secondary: 'rounded-xl border-2 border-border bg-white text-foreground hover:border-secondary/40 hover:text-secondary hover:bg-secondary/5 active:scale-[0.98]',
	ghost: 'rounded-xl text-muted-foreground hover:text-foreground hover:bg-muted/50 active:scale-[0.98]',
	accent: 'rounded-xl bg-accent text-white shadow-lg hover:bg-accent/90 hover:scale-[1.03] active:scale-[0.98]',
	'outline-white': 'rounded-xl border-2 border-white/30 text-white hover:bg-white/10 hover:border-white/50 active:scale-[0.98]',
};
---
<a href={href} target={target} rel={rel} class={`${baseClasses} ${sizeClasses[size]} ${variants[variant]}`}>
	{title || "Start Your Practice's Revenue Recovery"}
	{variant === 'primary' && (
		<svg class="w-4 h-4 transform transition-transform duration-300 group-hover:translate-x-0.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
			<path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3" />
		</svg>
	)}
</a>