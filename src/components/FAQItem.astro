---
interface Props {
	question: string;
	answer: string;
	delay?: string;
}

const { question, answer, delay } = Astro.props;
---
<div class="reveal card-premium overflow-hidden" style={`transition-delay: ${delay || '0ms'}`}>
	<button 
		class="faq-button w-full flex items-center justify-between gap-4 px-6 py-5 text-left hover:bg-muted/30 transition-colors duration-200"
		aria-expanded="false"
	>
		<span class="font-semibold text-foreground text-sm sm:text-base pr-4">{question}</span>
		<div class="flex-shrink-0 w-7 h-7 rounded-full bg-secondary/10 flex items-center justify-center group-hover:bg-secondary/20 transition-colors">
			<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-chevron-down w-4 h-4 text-secondary transition-transform duration-300"><path d="m6 9 6 6 6-6"></path></svg>
		</div>
	</button>
	<div class="faq-answer max-h-0 overflow-hidden transition-all duration-300 ease-out">
		<div class="px-6 pb-5 text-sm text-muted-foreground leading-relaxed max-w-2xl border-t border-border/60 pt-4">
			{answer}
		</div>
	</div>
</div>
