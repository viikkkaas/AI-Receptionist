---
import Layout from '../layouts/Layout.astro';
import Button from '../components/Button.astro';
import FeatureCard from '../components/FeatureCard.astro';
import FAQItem from '../components/FAQItem.astro';
import ResultsROI from '../components/ResultsROI.tsx';
import RevenueCalculator from '../components/RevenueCalculator.tsx';
import Testimonials from '../components/Testimonials.tsx';
import { PricingSection } from '../components/PricingSection.tsx';
import { FinalCTA } from '../components/FinalCTA.tsx';
---

<Layout>
	<div id="top" class="min-h-screen bg-background text-foreground selection:bg-secondary/20 overflow-x-hidden pb-[72px] md:pb-0">
		<!-- ==================== DESKTOP HEADER (unchanged) ==================== -->
		<header class="hidden md:block fixed top-0 inset-x-0 z-50 transition-all duration-500 bg-transparent border-b border-transparent contain-paint" id="main-header">
			<nav class="container-custom h-20 flex items-center justify-between transition-all duration-500" id="nav-container">
				<a href="#top" class="font-extrabold tracking-tight text-xl flex items-center gap-2 group text-primary">
					<span>CareReceptionist</span><span class="text-secondary"> AI</span>
				</a>

				<div class="hidden md:flex items-center gap-10 text-sm font-semibold text-muted-foreground">
					<a href="#problem" class="hover:text-secondary transition-colors relative group py-2">
						Problem
						<span class="absolute bottom-0 left-0 w-0 h-0.5 bg-secondary transition-all duration-300 group-hover:w-full"></span>
					</a>
					<a href="#solution" class="hover:text-secondary transition-colors relative group py-2">
						Solution
						<span class="absolute bottom-0 left-0 w-0 h-0.5 bg-secondary transition-all duration-300 group-hover:w-full"></span>
					</a>
					<a href="/how-it-works" class="hover:text-secondary transition-colors relative group py-2">
						How It Works
						<span class="absolute bottom-0 left-0 w-0 h-0.5 bg-secondary transition-all duration-300 group-hover:w-full"></span>
					</a>
					<a href="#pricing" class="hover:text-secondary transition-colors relative group py-2">
						Pricing
						<span class="absolute bottom-0 left-0 w-0 h-0.5 bg-secondary transition-all duration-300 group-hover:w-full"></span>
					</a>
				</div>

				<div class="hidden md:flex items-center gap-4">
					<Button title="Start Revenue Recovery →" />
				</div>

				<button class="md:hidden p-3 -mr-3 flex items-center justify-center text-primary z-[60] relative" aria-label="Toggle menu" id="mobile-menu-button" aria-expanded="false" aria-controls="mobile-menu">
					<div class="w-6 h-5 relative flex flex-col justify-between">
						<span class="w-full h-0.5 bg-current transition-all duration-300 origin-left" id="menu-bar-1"></span>
						<span class="w-full h-0.5 bg-current transition-all duration-300" id="menu-bar-2"></span>
						<span class="w-full h-0.5 bg-current transition-all duration-300 origin-left" id="menu-bar-3"></span>
					</div>
				</button>
			</nav>

			<div id="mobile-menu" class="fixed inset-0 z-50 invisible opacity-0 transition-all duration-300 md:hidden">
				<div class="absolute inset-0 bg-white/95 backdrop-blur-2xl"></div>
				<div class="relative h-full flex flex-col items-center justify-center gap-8 p-8 text-center">
					<a href="#problem" class="text-3xl font-bold text-primary hover:text-secondary transition-colors mobile-link">Problem</a>
					<a href="#solution" class="text-3xl font-bold text-primary hover:text-secondary transition-colors mobile-link">Solution</a>
					<a href="/how-it-works" class="text-3xl font-bold text-primary hover:text-secondary transition-colors mobile-link">How It Works</a>
					<a href="#pricing" class="text-3xl font-bold text-primary hover:text-secondary transition-colors mobile-link">Pricing</a>
					<div class="mt-4 scale-125">
						<Button title="Start Revenue Recovery →" />
					</div>
				</div>
			</div>
		</header>

		<!-- ==================== MOBILE BOTTOM NAV BAR ==================== -->
		<nav class="md:hidden fixed bottom-0 inset-x-0 z-50 bg-white/95 backdrop-blur-xl border-t border-border/80 safe-bottom will-change-transform" id="mobile-bottom-nav">
			<div class="flex items-center justify-around h-[72px] px-2 max-w-xl mx-auto">
				<a href="#top" class="flex flex-col items-center justify-center gap-1 min-w-[56px] py-2 bottom-nav-link text-secondary">
					<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-home"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path><polyline points="9 22 9 12 15 12 15 22"></polyline></svg>
					<span class="text-[10px] font-semibold">Home</span>
				</a>
				<a href="/how-it-works" class="flex flex-col items-center justify-center gap-1 min-w-[56px] py-2 bottom-nav-link text-muted-foreground hover:text-secondary transition-colors">
					<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-info"><circle cx="12" cy="12" r="10"></circle><path d="M12 16v-4"></path><path d="M12 8h.01"></path></svg>
					<span class="text-[10px] font-semibold">How It Works</span>
				</a>
				<a href="#pricing" class="flex flex-col items-center justify-center gap-1 min-w-[56px] py-2 bottom-nav-link text-muted-foreground hover:text-secondary transition-colors">
					<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-tag"><path d="M12 2H2v10l9.29 9.29c.94.94 2.48.94 3.42 0l6.58-6.58c.94-.94.94-2.48 0-3.42L12 2Z"></path><path d="M7 7h.01"></path></svg>
					<span class="text-[10px] font-semibold">Pricing</span>
				</a>
				<a href="https://calendly.com/vikas-p-2706/30min" target="_blank" rel="noopener noreferrer" class="flex flex-col items-center justify-center gap-1 min-w-[56px] py-2 text-muted-foreground hover:text-secondary transition-colors">
					<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-calendar"><path d="M8 2v4"></path><path d="M16 2v4"></path><rect width="18" height="18" x="3" y="4" rx="2"></rect><path d="M3 10h18"></path></svg>
					<span class="text-[10px] font-semibold">Book Demo</span>
				</a>
			</div>
		</nav>

		<main>
			<!-- ==================== DESKTOP HERO (unchanged) ==================== -->
			<section class="hidden md:block relative pt-18 pb-20 sm:pt-[104px] sm:pb-32 overflow-hidden bg-white">
				<div class="absolute inset-0 pointer-events-none bg-[radial-gradient(circle_at_50%_-20%,rgba(59,130,246,0.06),transparent_70%)]"></div>

				<div class="relative container-custom grid lg:grid-cols-2 gap-10 lg:gap-16 items-center">
					<div class="flex flex-col items-start reveal">
						<div class="inline-flex items-center gap-2 rounded-full bg-secondary/10 border border-secondary/20 px-4 py-1.5 text-xs font-semibold text-secondary mb-5 sm:mb-6">
							<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-building w-3.5 h-3.5"><rect width="16" height="16" x="4" y="2" rx="2" ry="2"></rect><path d="M9 22v-4h6v4"></path><path d="M8 6h.01"></path><path d="M16 6h.01"></path><path d="M12 6h.01"></path><path d="M12 10h.01"></path><path d="M12 14h.01"></path><path d="M16 10h.01"></path><path d="M16 14h.01"></path><path d="M8 10h.01"></path><path d="M8 14h.01"></path></svg>
							Built for high-end US dental clinics
						</div>

						<h1 class="text-[33px] sm:text-[57px] lg:text-[69px] font-black tracking-tight leading-[1.08] text-primary">
							The Front Office Operating System for<br />
							<span class="text-secondary">Growing Dental Practices.</span>
						</h1>

						<p class="mt-5 sm:mt-6 text-[16px] sm:text-[18px] text-muted-foreground max-w-xl leading-relaxed">
							Your front desk handles patients in the chair. We handle everything else — the calls, the scheduling, the follow-ups, the reviews. One system. No extra headcount.
						</p>

						<p class="mt-3 text-sm font-semibold text-secondary">
							Practices using CareReceptionist recover an average of $10K+ per month in previously missed revenue.
						</p>

						<div class="mt-6 sm:mt-8 flex flex-col sm:flex-row gap-3 sm:gap-4 w-full sm:w-auto">
							<Button title="Start Your Practice's Revenue Recovery →" />
							<a href="#problem" class="inline-flex items-center justify-center gap-2 rounded-xl border-2 border-border bg-white px-8 py-3.5 text-base font-semibold text-foreground hover:border-secondary/40 hover:text-secondary hover:bg-secondary/5 transition-all hover:scale-[1.02] active:scale-[0.98]">
								See What You're Missing
							</a>
						</div>

						<div class="mt-6 sm:mt-8 flex flex-wrap items-center gap-x-5 sm:gap-x-6 gap-y-2 text-xs text-muted-foreground font-medium">
							<span class="flex items-center gap-1.5">
								<svg class="w-3.5 h-3.5 text-secondary" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
								HIPAA Compliant | BAA Signed
							</span>
							<span class="flex items-center gap-1.5">
								<svg class="w-3.5 h-3.5 text-secondary" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
								Live in 7 Days
							</span>
							<span class="flex items-center gap-1.5">
								<svg class="w-3.5 h-3.5 text-secondary" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
								Integrates with Dentrix & Eaglesoft
							</span>
							<span class="flex items-center gap-1.5">
								<svg class="w-3.5 h-3.5 text-secondary" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
								No Long-Term Contracts
							</span>
						</div>
					</div>

					<div class="relative lg:block reveal" style="transition-delay: 200ms">
						<div class="relative bg-white rounded-2xl shadow-2xl border border-border/80 group overflow-hidden">
							<div class="rounded-xl w-full aspect-[4/3] bg-gradient-to-br from-primary via-primary/95 to-secondary/20 flex items-center justify-center overflow-hidden relative group-hover:scale-[1.02] transition-transform duration-700">
								<img src="https://images.unsplash.com/photo-1629909613654-28e377c37b09?auto=format&fit=crop&q=80&w=800" alt="Modern dental practice" class="w-full h-full object-cover" loading="lazy" />
							</div>
							<div class="absolute inset-0 bg-gradient-to-t from-primary/20 to-transparent pointer-events-none"></div>

							<div class="absolute top-4 sm:top-6 -right-2 sm:-right-3 glass p-3 rounded-xl sm:p-3.5 sm:rounded-xl shadow-xl animate-bounce-slow">
								<div class="flex items-center gap-3">
									<div class="w-9 h-9 rounded-full bg-secondary flex items-center justify-center">
										<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-white"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
									</div>
									<div>
										<div class="text-[10px] text-muted-foreground uppercase font-bold tracking-wider">Patient Booking</div>
										<div class="text-xs font-bold text-primary">"I need a cleaning next Thursday."</div>
									</div>
								</div>
							</div>
						</div>
					</div>
				</div>
			</section>

			<!-- ==================== MOBILE HERO ==================== -->
			<section class="md:hidden relative pt-14 pb-10 overflow-hidden bg-white">
				<div class="absolute inset-0 pointer-events-none bg-[radial-gradient(circle_at_50%_-20%,rgba(59,130,246,0.06),transparent_70%)]"></div>

				<div class="relative px-5 max-w-xl mx-auto">
					<div class="flex items-center gap-2 rounded-full bg-secondary/10 border border-secondary/20 px-3.5 py-1 text-[11px] font-semibold text-secondary mb-5 w-fit">
						Built for US dental clinics
					</div>

					<h1 class="text-[28px] font-black tracking-tight leading-[1.12] text-primary">
						The Front Office OS for<br />
						<span class="text-secondary">Growing Dental Practices.</span>
					</h1>

					<p class="mt-4 text-[15px] text-muted-foreground leading-relaxed">
						Your front desk handles patients in the chair. We handle the calls, scheduling, follow-ups, and reviews — automatically.
					</p>

					<p class="mt-3 text-sm font-semibold text-secondary">
						Recover $10K+/month in previously missed revenue.
					</p>

					<div class="mt-6 flex flex-col gap-3">
						<a href="https://calendly.com/vikas-p-2706/30min" target="_blank" rel="noopener noreferrer" class="flex items-center justify-center gap-2 rounded-xl gradient-accent text-primary-foreground shadow-glow px-6 py-4 text-base font-bold active:scale-[0.97] transition-all duration-200">
							Start Revenue Recovery
							<svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3" />
							</svg>
						</a>
						<a href="#problem" class="flex items-center justify-center gap-2 rounded-xl border-2 border-border bg-white px-6 py-3.5 text-sm font-semibold text-foreground active:scale-[0.97] transition-all duration-200">
							See What You're Missing
						</a>
					</div>

					<div class="mt-5 flex flex-wrap items-center gap-x-4 gap-y-1.5 text-[11px] text-muted-foreground font-medium">
						<span class="flex items-center gap-1">
							<svg class="w-3 h-3 text-secondary shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
							HIPAA Compliant
						</span>
						<span class="flex items-center gap-1">
							<svg class="w-3 h-3 text-secondary shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
							Live in 7 Days
						</span>
						<span class="flex items-center gap-1">
							<svg class="w-3 h-3 text-secondary shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
							No Contracts
						</span>
					</div>

					<div class="mt-8 -mx-5">
						<div class="relative bg-white rounded-2xl shadow-xl border border-border/80 mx-5 overflow-hidden">
							<div class="w-full aspect-[4/3] bg-gradient-to-br from-primary via-primary/95 to-secondary/20 overflow-hidden">
								<img src="https://images.unsplash.com/photo-1629909613654-28e377c37b09?auto=format&fit=crop&q=80&w=800" alt="Modern dental practice" class="w-full h-full object-cover" loading="lazy" />
							</div>
							<div class="absolute top-3 -right-1 glass p-2.5 rounded-xl shadow-lg">
								<div class="flex items-center gap-2">
									<div class="w-7 h-7 rounded-full bg-secondary flex items-center justify-center shrink-0">
										<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-white"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
									</div>
									<div>
										<div class="text-[9px] text-muted-foreground uppercase font-bold tracking-wider">Patient Booking</div>
										<div class="text-[11px] font-bold text-primary">"I need a cleaning next Thursday."</div>
									</div>
								</div>
							</div>
						</div>
					</div>
				</div>
			</section>

			<!-- ==================== DESKTOP TRUST STRIP (unchanged) ==================== -->
			<div class="hidden md:flex bg-primary py-5">
				<div class="container-custom flex flex-col md:flex-row items-center justify-center gap-8 md:gap-14 text-white/80 text-sm font-medium">
					<div class="flex items-center gap-2.5">
						<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-accent"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg>
						<span>HIPAA Compliant Infrastructure</span>
					</div>
					<div class="flex items-center gap-2.5">
						<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-accent"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line><polyline points="10 9 9 9 8 9"></polyline></svg>
						<span>We Sign BAA Agreements</span>
					</div>
					<div class="flex items-center gap-2.5">
						<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-accent"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg>
						<span>256-bit Secure Encryption</span>
					</div>
				</div>
			</div>

			<!-- ==================== MOBILE TRUST STRIP ==================== -->
			<div class="md:hidden bg-primary py-3.5 overflow-hidden">
				<div class="flex items-center gap-6 overflow-x-auto px-5 scrollbar-none snap-x snap-mandatory" style="-webkit-overflow-scrolling: touch;">
					<div class="flex items-center gap-2 text-white/80 text-[12px] font-medium shrink-0 snap-start">
						<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-accent shrink-0"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg>
						<span>HIPAA Compliant</span>
					</div>
					<div class="flex items-center gap-2 text-white/80 text-[12px] font-medium shrink-0 snap-start">
						<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-accent shrink-0"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line><polyline points="10 9 9 9 8 9"></polyline></svg>
						<span>BAA Signed</span>
					</div>
					<div class="flex items-center gap-2 text-white/80 text-[12px] font-medium shrink-0 snap-start">
						<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-accent shrink-0"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg>
						<span>256-bit Encryption</span>
					</div>
					<div class="flex items-center gap-2 text-white/80 text-[12px] font-medium shrink-0 snap-start">
						<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-accent shrink-0"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
						<span>Live in 7 Days</span>
					</div>
					<div class="flex items-center gap-2 text-white/80 text-[12px] font-medium shrink-0 snap-start">
						<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-accent shrink-0"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
						<span>Dentrix & Eaglesoft</span>
					</div>
				</div>
			</div>

			<!-- Results & ROI Section (Problem) — shared component, unchanged -->
			<ResultsROI client:visible />

			<!-- Pain Amplification / Revenue Calculator — shared component, unchanged -->
			<RevenueCalculator client:visible />

