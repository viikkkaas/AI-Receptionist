<script>
	// ==================== NEW MOBILE BOTTOM NAV ACTIVE LINK ====================
	(function() {
		const navLinks = document.querySelectorAll('#mobile-bottom-nav .bottom-nav-link');
		const sections = ['#top', '/how-it-works', '#pricing'];
		const currentPath = window.location.pathname;

		navLinks.forEach((link, i) => {
			const href = link.getAttribute('href');
			if (href === currentPath || (href.startsWith('#') && i === 0 && (currentPath === '/' || currentPath === ''))) {
				link.classList.add('text-secondary');
				link.classList.remove('text-muted-foreground');
			}
		});
	})();

	// ==================== MOBILE STICKY CTA ON SCROLL ====================
	(function() {
		const stickyCta = document.getElementById('mobile-sticky-cta');
		if (!stickyCta) return;

		let ctaShown = false;
		const heroEnd = document.querySelector('.md\\:hidden.pt-14') || document.querySelector('section');

		window.addEventListener('scroll', () => {
			if (window.innerWidth >= 768) return;
			const scrollY = window.scrollY || window.pageYOffset;

			if (scrollY > 400 && !ctaShown) {
				stickyCta.classList.remove('translate-y-full', 'opacity-0');
				ctaShown = true;
			} else if (scrollY <= 400 && ctaShown) {
				stickyCta.classList.add('translate-y-full', 'opacity-0');
				ctaShown = false;
			}
		}, { passive: true });
	})();

	// ==================== EXISTING DESKTOP HEADER SCROLL BEHAVIOR ====================
	const header = document.getElementById('main-header');
	const navContainer = document.getElementById('nav-container');
	const isMobile = () => window.innerWidth < 768;

	window.addEventListener('scroll', () => {
		if (!header) return;
		if (window.scrollY > 20) {
			if (isMobile()) {
				header.classList.add('bg-white', 'border-border/80', 'shadow-sm');
				header.classList.remove('bg-transparent', 'border-transparent', 'backdrop-blur-lg');
			} else {
				header.classList.add('bg-white/80', 'backdrop-blur-lg', 'border-border/80', 'shadow-sm');
				header.classList.remove('bg-transparent', 'border-transparent');
			}
			navContainer?.classList.remove('h-20');
			navContainer?.classList.add('h-16');
		} else {
			header.classList.remove('bg-white/80', 'backdrop-blur-lg', 'border-border/80', 'shadow-sm', 'bg-white');
			header.classList.add('bg-transparent', 'border-transparent');
			navContainer?.classList.add('h-20');
			navContainer?.classList.remove('h-16');
		}
	});

	// ==================== EXISTING MOBILE MENU TOGGLE ====================
	const mobileMenuButton = document.getElementById('mobile-menu-button');
	const mobileMenu = document.getElementById('mobile-menu');
	const mobileLinks = document.querySelectorAll('.mobile-link');
	const menuBars = [
		document.getElementById('menu-bar-1'),
		document.getElementById('menu-bar-2'),
		document.getElementById('menu-bar-3')
	];

	function toggleMenu() {
		if (!mobileMenuButton || !mobileMenu) return;
		const isExpanded = mobileMenuButton.getAttribute('aria-expanded') === 'true';
		mobileMenuButton.setAttribute('aria-expanded', (!isExpanded).toString());

		if (!isExpanded) {
			mobileMenu.classList.remove('invisible', 'opacity-0');
			mobileMenu.classList.add('visible', 'opacity-100');
			document.body.style.overflow = 'hidden';
			menuBars[0]?.classList.add('rotate-45', 'translate-y-[9px]');
			menuBars[1]?.classList.add('opacity-0', 'translate-x-2');
			menuBars[2]?.classList.add('-rotate-45', '-translate-y-[9px]');
		} else {
			mobileMenu.classList.add('invisible', 'opacity-0');
			mobileMenu.classList.remove('visible', 'opacity-100');
			document.body.style.overflow = '';
			menuBars[0]?.classList.remove('rotate-45', 'translate-y-[9px]');
			menuBars[1]?.classList.remove('opacity-0', 'translate-x-2');
			menuBars[2]?.classList.remove('-rotate-45', '-translate-y-[9px]');
		}
	}

	mobileMenuButton?.addEventListener('click', toggleMenu);

	mobileLinks.forEach(link => {
		link.addEventListener('click', () => {
			if (mobileMenuButton?.getAttribute('aria-expanded') === 'true') {
				toggleMenu();
			}
		});
	});

	// ==================== EXISTING REVEAL OBSERVER ====================
	const revealElements = document.querySelectorAll('.reveal');
	const observer = new IntersectionObserver((entries) => {
		entries.forEach(entry => {
			if (entry.isIntersecting) {
				entry.target.classList.add('active');
				observer.unobserve(entry.target);
			}
		});
	}, { threshold: 0.05, rootMargin: '50px' });

	revealElements.forEach(el => observer.observe(el));

	// ==================== EXISTING FAQ ACCORDION ====================
	const faqButtons = document.querySelectorAll('.faq-button');
	faqButtons.forEach(button => {
		button.addEventListener('click', () => {
			const answer = button.nextElementSibling;
			const icon = button.querySelector('svg');
			const isExpanded = button.getAttribute('aria-expanded') === 'true';

			faqButtons.forEach(otherButton => {
				if (otherButton !== button) {
					const otherAnswer = otherButton.nextElementSibling;
					if (otherAnswer) otherAnswer.style.maxHeight = '0';
					otherButton.querySelector('svg')?.classList.remove('rotate-180');
					otherButton.setAttribute('aria-expanded', 'false');
				}
			});

			if (!isExpanded && answer) {
				answer.style.maxHeight = answer.scrollHeight + 'px';
				icon?.classList.add('rotate-180');
				button.setAttribute('aria-expanded', 'true');
			} else if (answer) {
				answer.style.maxHeight = '0';
				icon?.classList.remove('rotate-180');
				button.setAttribute('aria-expanded', 'false');
			}
		});
	});
</script>

