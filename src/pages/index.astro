---
import Layout from '../layouts/Layout.astro';
import Button from '../components/Button.astro';
import FeatureCard from '../components/FeatureCard.astro';
import FAQItem from '../components/FAQItem.astro';
import ResultsROI from '../components/ResultsROI.tsx';
import RevenueCalculator from '../components/RevenueCalculator.tsx';
import Testimonials from '../components/Testimonials.tsx';
import { PricingSection } from '../components/PricingSection.tsx';
import { FinalCTA } from '../components/FinalCTA.tsx';
---

<Layout>
	<div id="top" class="min-h-screen bg-background text-foreground selection:bg-secondary/20 overflow-x-hidden">
		<!-- Header -->
		<header class="fixed top-0 inset-x-0 z-50 transition-all duration-500 bg-transparent border-b border-transparent" id="main-header">
			<nav class="container-custom h-20 flex items-center justify-between transition-all duration-500" id="nav-container">
				<a href="#top" class="font-extrabold tracking-tight text-xl flex items-center gap-2 group text-primary">
					<span>CareReceptionist</span><span class="text-secondary"> AI</span>
				</a>

				<div class="hidden md:flex items-center gap-10 text-sm font-semibold text-muted-foreground">
					<a href="/how-it-works" class="hover:text-secondary transition-colors relative group py-2">
						How It Works
						<span class="absolute bottom-0 left-0 w-0 h-0.5 bg-secondary transition-all duration-300 group-hover:w-full"></span>
					</a>
					<a href="/#pricing" class="hover:text-secondary transition-colors relative group py-2">
						Pricing
						<span class="absolute bottom-0 left-0 w-0 h-0.5 bg-secondary transition-all duration-300 group-hover:w-full"></span>
					</a>
					<a href="/#features" class="hover:text-secondary transition-colors relative group py-2">
						Features
						<span class="absolute bottom-0 left-0 w-0 h-0.5 bg-secondary transition-all duration-300 group-hover:w-full"></span>
					</a>
					<a href="/#contact" class="hover:text-secondary transition-colors relative group py-2">
						Contact
						<span class="absolute bottom-0 left-0 w-0 h-0.5 bg-secondary transition-all duration-300 group-hover:w-full"></span>
					</a>
				</div>

				<div class="hidden md:flex items-center gap-4">
					<Button />
				</div>

				<button class="md:hidden p-3 -mr-3 flex items-center justify-center text-primary z-[60] relative" aria-label="Toggle menu" id="mobile-menu-button" aria-expanded="false" aria-controls="mobile-menu">
					<div class="w-6 h-5 relative flex flex-col justify-between">
						<span class="w-full h-0.5 bg-current transition-all duration-300 origin-left" id="menu-bar-1"></span>
						<span class="w-full h-0.5 bg-current transition-all duration-300" id="menu-bar-2"></span>
						<span class="w-full h-0.5 bg-current transition-all duration-300 origin-left" id="menu-bar-3"></span>
					</div>
				</button>
			</nav>

			<div id="mobile-menu" class="fixed inset-0 z-50 invisible opacity-0 transition-all duration-300 md:hidden">
				<div class="absolute inset-0 bg-white/95 backdrop-blur-2xl"></div>
				<div class="relative h-full flex flex-col items-center justify-center gap-8 p-8 text-center">
					<a href="/how-it-works" class="text-3xl font-bold text-primary hover:text-secondary transition-colors mobile-link">How It Works</a>
					<a href="#pricing" class="text-3xl font-bold text-primary hover:text-secondary transition-colors mobile-link">Pricing</a>
					<a href="#features" class="text-3xl font-bold text-primary hover:text-secondary transition-colors mobile-link">Features</a>
					<a href="#contact" class="text-3xl font-bold text-primary hover:text-secondary transition-colors mobile-link">Contact</a>
					<div class="mt-4 scale-125">
						<Button />
					</div>
				</div>
			</div>
		</header>

		<main>
			<!-- Hero Section -->
			<section class="relative pt-36 pb-20 sm:pt-52 sm:pb-32 overflow-hidden bg-white">
				<div class="absolute inset-0 pointer-events-none bg-[radial-gradient(circle_at_50%_-20%,rgba(59,130,246,0.06),transparent_70%)]"></div>

				<div class="relative container-custom grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
					<div class="flex flex-col items-start reveal">
						<div class="inline-flex items-center gap-2 rounded-full bg-secondary/10 px-4 py-1.5 text-xs font-semibold text-secondary mb-6">
							<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-shield-check w-3.5 h-3.5"><path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"></path><path d="m9 12 2 2 4-4"></path></svg>
							Built for high-end US dental clinics
						</div>

						<h1 class="text-4xl sm:text-6xl lg:text-7xl font-black tracking-tight leading-[1.08] text-primary">
							Never Miss a<br />
							<span class="text-secondary">New Patient</span> Again.
						</h1>

						<p class="mt-6 text-lg sm:text-xl text-muted-foreground max-w-xl leading-relaxed">
							24/7 AI receptionist that answers every call, books appointments instantly, sends SMS confirmations, and knows exactly when to hand off to your team.
						</p>

						<div class="mt-8 flex flex-col sm:flex-row gap-4 w-full sm:w-auto">
							<Button title="Book a Free Demo" />
							<a href="#demo" class="inline-flex items-center justify-center gap-2 rounded-xl border-2 border-border bg-white px-8 py-3.5 text-base font-semibold text-foreground hover:border-secondary/40 hover:text-secondary hover:bg-secondary/5 transition-all hover:scale-[1.02] active:scale-[0.98]">
								<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-play w-4 h-4 fill-current"><path d="M5 5a2 2 0 0 1 3.008-1.728l11.997 6.998a2 2 0 0 1 .003 3.458l-12 7A2 2 0 0 1 5 19z"></path></svg>
								Watch Demo
							</a>
						</div>

						<!-- Trust signals below hero CTA -->
						<div class="mt-8 flex flex-wrap items-center gap-x-6 gap-y-2 text-xs text-muted-foreground font-medium">
							<span class="flex items-center gap-1.5">
								<svg class="w-3.5 h-3.5 text-accent" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
								HIPAA-conscious
							</span>
							<span class="flex items-center gap-1.5">
								<svg class="w-3.5 h-3.5 text-accent" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
								Live in 7 Days
							</span>
							<span class="flex items-center gap-1.5">
								<svg class="w-3.5 h-3.5 text-accent" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
								24/7 Coverage
							</span>
							<span class="flex items-center gap-1.5">
								<svg class="w-3.5 h-3.5 text-accent" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
								No Contracts
							</span>
						</div>
					</div>

					<div class="relative lg:block reveal" style="transition-delay: 200ms">
						<div class="relative bg-white rounded-2xl p-6 shadow-2xl border border-border/80 group overflow-hidden">
							<div class="rounded-xl w-full aspect-[4/3] bg-gradient-to-br from-primary via-primary/95 to-secondary/20 flex items-center justify-center overflow-hidden relative group-hover:scale-[1.02] transition-transform duration-700">
								<img src="https://images.unsplash.com/photo-1629909613654-28e377c37b09?auto=format&fit=crop&q=80&w=800" alt="Dental clinic" class="w-full h-full object-cover" loading="lazy" />
							</div>
							<div class="absolute inset-0 bg-gradient-to-t from-primary/20 to-transparent pointer-events-none"></div>

							<div class="absolute top-6 -right-3 glass p-3.5 rounded-xl shadow-xl animate-bounce-slow">
								<div class="flex items-center gap-3">
									<div class="w-9 h-9 rounded-full bg-accent flex items-center justify-center">
										<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-white"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
									</div>
									<div>
										<div class="text-[10px] text-muted-foreground uppercase font-bold tracking-wider">Patient Experience</div>
										<div class="text-xs font-bold text-primary">"Is Dr. Smith available for a cleaning?"</div>
									</div>
								</div>
							</div>
						</div>
					</div>
				</div>
			</section>

			<!-- Trust Strip -->
			<div class="bg-primary py-5">
				<div class="container-custom flex flex-col md:flex-row items-center justify-center gap-8 md:gap-14 text-white/80 text-sm font-medium">
					<div class="flex items-center gap-2.5">
						<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-accent"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg>
						<span>HIPAA Compliant Infrastructure</span>
					</div>
					<div class="flex items-center gap-2.5">
						<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-accent"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line><polyline points="10 9 9 9 8 9"></polyline></svg>
						<span>We Sign BAA Agreements</span>
					</div>
					<div class="flex items-center gap-2.5">
						<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-accent"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg>
						<span>256-bit Secure Encryption</span>
					</div>
				</div>
			</div>

			<!-- Results & ROI Section -->
			<ResultsROI client:visible />

			<!-- Revenue Calculator -->
			<RevenueCalculator client:visible />

			<!-- Safety Net Section -->
			<section class="section-padding bg-primary relative overflow-hidden border-y border-white/10">
				<div class="absolute inset-0 bg-[radial-gradient(ellipse_80%_50%_at_50%_0%,rgba(59,130,246,0.06),transparent_70%)] pointer-events-none"></div>
				<div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[600px] bg-secondary/5 blur-[120px] rounded-full pointer-events-none" />

				<div class="container-custom relative z-10">
					<div class="section-header">
						<div class="reveal">
							<div class="inline-flex items-center gap-2 rounded-full bg-white/10 px-4 py-1.5 text-xs font-semibold text-secondary mb-5">
								Zero-Error Philosophy
							</div>
							<h2 class="text-3xl sm:text-4xl md:text-5xl font-extrabold tracking-tight text-white">Smart Enough for Routine.<br /> Confident Enough to Hand Off.</h2>
							<p class="mt-4 text-white/60 text-lg">Built to handle the routine, and smart enough to know when to escalate.</p>
						</div>
					</div>

					<div class="grid md:grid-cols-3 gap-6 relative">
						<div class="hidden md:block absolute top-1/2 left-[30%] right-[30%] h-px bg-white/10 -translate-y-1/2 z-0"></div>

						<div class="reveal relative z-10 flex flex-col items-center text-center p-8 rounded-2xl bg-white/[0.03] border border-white/10 hover:bg-white/[0.06] hover:border-secondary/30 transition-all duration-300" style="transition-delay: 0ms">
							<div class="w-14 h-14 rounded-xl bg-secondary/20 border border-secondary/30 flex items-center justify-center text-secondary mb-6">
								<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg>
							</div>
							<h3 class="font-bold text-xl mb-3 text-white">1. Triage</h3>
							<p class="text-sm text-white/60 leading-relaxed">AI instantly identifies the intent: booking, question, or complex inquiry.</p>
						</div>

						<div class="reveal relative z-10 flex flex-col items-center text-center p-8 rounded-2xl bg-white/[0.03] border border-white/10 hover:bg-white/[0.06] hover:border-secondary/30 transition-all duration-300" style="transition-delay: 100ms">
							<div class="w-14 h-14 rounded-xl bg-secondary/20 border border-secondary/30 flex items-center justify-center text-secondary mb-6">
								<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
							</div>
							<h3 class="font-bold text-xl mb-3 text-white">2. Resolve</h3>
							<p class="text-sm text-white/60 leading-relaxed">Routine calls are handled instantly — bookings, hours, insurance questions.</p>
						</div>

						<div class="reveal relative z-10 flex flex-col items-center text-center p-8 rounded-2xl bg-accent/[0.03] border border-accent/20 hover:bg-accent/[0.06] hover:border-accent/40 transition-all duration-300" style="transition-delay: 200ms">
							<div class="w-14 h-14 rounded-xl bg-accent/20 border border-accent/30 flex items-center justify-center text-accent mb-6">
								<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><line x1="19" x2="19" y1="8" y2="14"></line><line x1="22" x2="16" y1="11" y2="11"></line></svg>
							</div>
							<h3 class="font-bold text-xl mb-3 text-white">3. Handoff</h3>
							<p class="text-sm text-white/60 leading-relaxed">Complex cases or emergencies are flagged. Your team steps in immediately.</p>
						</div>
					</div>
				</div>
			</section>

			<!-- Features Section -->
			<section id="features" class="section-padding scroll-mt-24 bg-white">
				<div class="container-custom">
					<div class="section-header">
						<div class="reveal">
							<div class="badge mb-5">
								Built for Dental
							</div>
							<h2 class="text-3xl sm:text-4xl md:text-5xl font-extrabold tracking-tight text-primary">Everything Your Front Desk Needs to Stay Ahead</h2>
							<p class="mt-4 text-muted-foreground text-lg">Clinical-grade capabilities that work alongside your team.</p>
						</div>
					</div>

					<div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
						<FeatureCard title="Answers Every Call, Every Time" description="First-ring pickup means no patient is ever left waiting — even during lunch rushes.">
							<svg slot="icon" xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-secondary"><path d="M16 2v6h6"></path><path d="m22 2-6 6"></path><path d="M13.832 16.568a1 1 0 0 0 1.213-.303l.355-.465A2 2 0 0 1 17 15h3a2 2 0 0 1 2 2v3a2 2 0 0 1-2 2A18 18 0 0 1 2 4a2 2 0 0 1 2-2h3a2 2 0 0 1 2 2v3a2 2 0 0 1-.8 1.6l-.468.351a1 1 0 0 0-.292 1.233 14 14 0 0 0 6.392 6.384"></path></svg>
						</FeatureCard>

						<FeatureCard title="Books Appointments Automatically" description="Integrates with your practice management software to schedule real appointments in real-time." delay="100ms">
							<svg slot="icon" xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-secondary"><path d="M16 14v2.2l1.6 1"></path><path d="M16 2v4"></path><path d="M21 7.5V6a2 2 0 0 0-2-2H5a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h3.5"></path><path d="M3 10h5"></path><path d="M8 2v4"></path><circle cx="16" cy="16" r="6"></circle></svg>
						</FeatureCard>

						<FeatureCard title="Flags Emergencies Instantly" description="Trained to identify clinical emergencies and prioritize them for immediate human attention." delay="200ms">
							<svg slot="icon" xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-secondary"><path d="M18 5h4"></path><path d="M20 3v4"></path><path d="M20.985 12.486a9 9 0 1 1-9.473-9.472c.405-.022.617.46.402.803a6 6 0 0 0 8.268 8.268c.344-.215.825-.004.803.401"></path></svg>
						</FeatureCard>

						<FeatureCard title="Smart SMS Notifications" description="Automatically sends booking confirmations, reschedule alerts, and cancellation notices to keep every patient informed." delay="300ms">
							<svg slot="icon" xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-secondary"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path><line x1="8" x2="16" y1="10" y2="10"></line><line x1="8" x2="16" y1="14" y2="14"></line></svg>
						</FeatureCard>

						<FeatureCard title="Review Request Automation" description="Automatically sends review requests after completed appointments to boost your Google presence and local SEO." delay="400ms">
							<svg slot="icon" xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-secondary"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon></svg>
						</FeatureCard>

						<FeatureCard title="HIPAA-Compliant by Design" description="Enterprise-grade security and signed BAA agreements protect every patient conversation." delay="500ms">
							<svg slot="icon" xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-secondary"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg>
						</FeatureCard>
					</div>

					<!-- Trust signal near features -->
					<div class="reveal mt-12 text-center">
						<p class="text-sm text-muted-foreground/60 font-medium">
							Trusted by growing dental practices across the United States.
						</p>
					</div>
				</div>
			</section>

			<!-- Demo Section -->
			<section id="demo" class="section-padding scroll-mt-24 bg-muted/30">
				<div class="container-custom max-w-5xl">
					<div class="section-header">
						<div class="reveal">
							<div class="badge mb-5">
								See It in Action
							</div>
							<h2 class="text-3xl sm:text-4xl md:text-5xl font-extrabold tracking-tight text-primary">Hear It in Action</h2>
							<p class="mt-4 text-muted-foreground text-lg">Watch our AI handle a real dental patient call — from greeting to booking.</p>
						</div>
					</div>

					<div class="reveal relative rounded-xl overflow-hidden shadow-2xl border border-border/80" style="padding-bottom: 56.25%;">
						<iframe class="absolute inset-0 w-full h-full rounded-xl" src="https://www.youtube.com/embed/aUCM9Es4mac" title="CareReceptionist AI Demo" frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen loading="lazy"></iframe>
					</div>
				</div>
			</section>

			<!-- About Section -->
			<section class="section-padding scroll-mt-24 bg-muted/30">
				<div class="container-custom max-w-5xl">
					<div class="section-header">
						<div class="reveal">
							<div class="badge mb-5">
								The Team
							</div>
							<h2 class="text-3xl sm:text-4xl md:text-5xl font-extrabold tracking-tight text-primary">Built by Dental Tech Experts</h2>
							<p class="mt-4 text-muted-foreground text-lg">We know dental workflows because we've built for them.</p>
						</div>
					</div>

					<div class="grid md:grid-cols-2 gap-6">
						<div class="reveal card-premium p-8 sm:p-10 flex flex-col items-center text-center group">
							<div class="relative w-36 h-36 rounded-full bg-secondary/20 p-1 shadow-lg transition-transform duration-500 group-hover:scale-105">
								<img src="https://res.cloudinary.com/dnpteehr6/image/upload/v1780252369/profile_photo_xhvzbu.jpg" alt="Vikas — Founder" class="w-full h-full rounded-full object-cover" loading="lazy" />
							</div>
							<div class="mt-5 font-extrabold text-2xl text-primary">Vikas</div>
							<div class="text-secondary text-xs font-bold uppercase tracking-widest mt-1">Founder & Lead Engineer</div>
							<p class="mt-4 text-sm text-muted-foreground leading-relaxed max-w-sm">
								AI specialist focused exclusively on dental clinics. Trained our AI to understand clinical procedures like <span class="text-secondary italic">prophy, SRP, and endodontics</span> — ensuring every patient conversation is professional and accurate.
							</p>
						</div>

						<div class="reveal card-premium p-8 sm:p-10 flex flex-col items-center text-center group">
